{
  "agent_id": "hermes",
  "user_id": "dev_user",
  "agent_type": "hermes",
  "action_types": ["RUN_COMMAND"],
  "bridge_secret": "change-me-hermes-dev-only",
  "policy_file": "policy.yaml",
  "adapter": {
    "runtime": "python",
    "python": "3.12",
    "module": "hermes_adapter.main",
    "source": "adapter",
    "socket": "~/.intentframe/integrations/hermes/adapter.sock"
  },
  "env": {
    "IF_AGENT_ADAPTER_SOCKET": "~/.intentframe/integrations/hermes/adapter.sock"
  }
}
