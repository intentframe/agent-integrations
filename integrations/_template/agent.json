{
  "agent_id": "example_agent",
  "user_id": "dev_user",
  "agent_type": "example_agent",
  "action_types": ["RUN_COMMAND"],
  "bridge_secret": "change-me-example-dev-only",
  "policy_file": "policy.yaml",
  "adapter": {
    "runtime": "python",
    "python": "3.12",
    "module": "example_adapter.main",
    "source": "adapter",
    "socket": "~/.intentframe/integrations/example_agent/adapter.sock"
  },
  "env": {
    "IF_AGENT_ADAPTER_SOCKET": "~/.intentframe/integrations/example_agent/adapter.sock"
  }
}
