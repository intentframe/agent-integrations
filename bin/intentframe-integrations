#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
if [[ -x "${ROOT}/.venv/bin/intentframe-integrations" ]]; then
  exec "${ROOT}/.venv/bin/intentframe-integrations" "$@"
fi
exec uv run --package intentframe-integrations-cli intentframe-integrations "$@"
