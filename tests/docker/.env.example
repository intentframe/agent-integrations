# Copy to tests/docker/.env and set your key:
#   cp tests/docker/.env.example tests/docker/.env
OPENAI_API_KEY=sk-your-key-here

# Optional: pin GitHub ref for install script + integration pack (default main).
# Use the same ref in the script URL and pack (entrypoint passes --ref automatically).
# REF=main
# REF=my-branch
# REF=v0.2.0
# REF=<commit-sha>
#
# Deprecated alias (still works):
# VERSION=main

# Optional: dashboard basic auth (defaults hermes / docker-test)
# HERMES_DASHBOARD_USER=hermes
# HERMES_DASHBOARD_PASSWORD=docker-test
