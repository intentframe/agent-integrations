# Copy to tests/docker/.env and set your key:
#   cp tests/docker/.env.example tests/docker/.env
OPENAI_API_KEY=sk-your-key-here

# Optional: pin GitHub branch/tag (default main)
# VERSION=main

# Optional: dashboard basic auth (defaults hermes / docker-test)
# HERMES_DASHBOARD_USER=hermes
# HERMES_DASHBOARD_PASSWORD=docker-test
